# LLM Provider configuration (Session 2 — kept for backwards compatibility)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai

# Default model for the configured provider. Can be overridden per request via
# the "model" field in POST /api/v1/estimate (handy for live A/B comparisons
# without restarting the server).
LLM_MODEL=gpt-4o-mini

# Application
APP_ENV=development
LOG_LEVEL=DEBUG

# --- Session 3 — LiteLLM wrapper ----------------------------------------------
# The wrapper tries PRIMARY_MODEL first and falls back to FALLBACK_MODEL on
# failure, with up to LLM_RETRIES attempts and an LLM_TIMEOUT-second deadline.
PRIMARY_MODEL=gpt-4o
FALLBACK_MODEL=claude-haiku-4-5-20251001
LLM_TIMEOUT=30
LLM_RETRIES=2

# --- Session 3 — Redis exact-match cache --------------------------------------
# Inside docker-compose, REDIS_URL is overridden to redis://redis:6379.
# When running uvicorn locally (outside Docker), use redis://localhost:6379.
REDIS_URL=redis://redis:6379
CACHE_TTL=86400

# --- Session 3 — Streamlit transport ------------------------------------------
# Streamlit hits the FastAPI service over HTTP. Point this to wherever the
# estimator is reachable from the machine running streamlit_app.py.
ESTIMATOR_API_BASE_URL=http://localhost:8000

# --- Session 4 — Semantic cache (redisvl + embeddings) ------------------------
# Cosine similarity threshold (0..1) above which a stored estimation is served
# as a cache hit. 0.92 is conservative; lower threshold = more recall, more
# false positives. Affines with the chosen embedding model.
EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_CACHE_THRESHOLD=0.85
SEMANTIC_CACHE_TTL=86400
# When true, the cache logs would-be hits but does NOT serve them — useful to
# calibrate the threshold against production traffic before flipping on.
SEMANTIC_CACHE_LOG_ONLY=false
